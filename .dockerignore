# ──────────────────────────────────────────────────────
# .dockerignore
# Docker 빌드 컨텍스트에서 제외할 파일 목록
# .gitignore와 별개로 관리 (이미지 크기 최소화)
# ──────────────────────────────────────────────────────

# Git
.git/
.gitignore
.github/

# 가상 환경
.venv/
venv/
env/
ENV/
.conda/

# Python 캐시
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/

# 테스트 / 커버리지
.pytest_cache/
.coverage
htmlcov/
tests/

# IDE
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# 로그
*.log
logs/

# 문서 (앱 실행에 불필요)
docs/
*.md
!README.md

# 민감 데이터 / 개인 데이터 파일
data/real_*.json
data/private_*.json
data/codef_*.json

# 빌드/배포 스크립트 (컨테이너 내부 불필요)
deploy/

# Docker 관련 (컨테이너 내부 불필요)
Dockerfile*
docker-compose*.yml
.dockerignore

# 임시 파일
*.tmp
*.bak
*.orig
